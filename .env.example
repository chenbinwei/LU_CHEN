# Copy this file to .env, then fill your real key.
# .env is ignored by git, so do not put real keys in .env.example.

# Text generation / review / human-style polish, using official DashScope SDK.
DASHSCOPE_API_KEY=put_your_dashscope_api_key_here
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/api/v1
DASHSCOPE_MODEL=qwen-plus-latest
DASHSCOPE_HUMANIZE_MODEL=qwen-plus-latest
DASHSCOPE_ENABLE_THINKING=false
DASHSCOPE_MAX_TOKENS=7000
DASHSCOPE_REPAIR_MAX_TOKENS=8000
DASHSCOPE_RETRIES=2
DASHSCOPE_TIMEOUT=90
DASHSCOPE_TEMPERATURE=0.3

# Final duration control. The pipeline auto-fits real TTS audio to the target duration.
DURATION_TOLERANCE=3.0

# Voice generation. Use fish for Fish Audio, ocool for OCool fallback, none for script-only preview.
TTS_MODE=fish
OCOOL_BASE_URL=https://one.ocoolai.com/v1
OCOOL_TTS_MODEL=tts-1-hd
OCOOL_TTS_VOICE=echo
OCOOL_TTS_SPEED=0.72

# Fish Audio TTS / voice clone
FISH_API_KEY=put_your_fish_audio_key_here
FISH_BASE_URL=https://api.fish.audio
FISH_TTS_MODEL=s2.1-pro-free
FISH_REFERENCE_ID=
FISH_TTS_SPEED=1.0
FISH_TTS_VOLUME=0
FISH_TTS_LATENCY=normal
FISH_MODEL_TITLE=video-slicer-voice
FISH_MODEL_DESCRIPTION=Voice model for video slicing narration.
FISH_MODEL_VISIBILITY=private

# Optional background music mixed under the final narration.
# Put local music files under assets/bgm/ or another ignored local folder.
BGM_AUDIO=
BGM_VOLUME=0.25
VOICEOVER_VOLUME=1.0
BGM_START=0
BGM_FADE_IN=0
BGM_FADE_OUT=2.5
