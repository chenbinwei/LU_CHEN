# Copy this file to .env, then fill your real key.
# .env is ignored by git, so do not put real keys in .env.example.

OCOOL_API_KEY=put_your_ocool_api_key_here
OCOOL_BASE_URL=https://one.ocoolai.com/v1

# Text model used in the verified demo run.
OCOOL_MODEL=gpt-4.1
OCOOL_HUMANIZE_MODEL=qwen-plus-latest

# Voice generation. Use ocool for API TTS, windows for local fallback, none for script-only preview.
TTS_MODE=ocool
OCOOL_TTS_MODEL=tts-1-hd
OCOOL_TTS_VOICE=echo
OCOOL_TTS_SPEED=0.72

# Optional local Windows TTS fallback settings
WINDOWS_TTS_VOICE=Microsoft Huihui Desktop
WINDOWS_TTS_RATE=0
WINDOWS_TTS_VOLUME=100
